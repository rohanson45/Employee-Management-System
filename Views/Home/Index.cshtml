@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <h2>Dashboard</h2>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-icon bg-blue">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <div class="stat-value">@ViewBag.TotalEmployees</div>
                <div class="stat-label">Total Employees</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-icon bg-green">
                <i class="bi bi-diagram-3-fill"></i>
            </div>
            <div>
                <div class="stat-value">@ViewBag.TotalDepartments</div>
                <div class="stat-label">Total Departments</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-icon bg-orange">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div>
                <div class="stat-value">@(((decimal)ViewBag.AverageSalary).ToString("N0"))</div>
                <div class="stat-label">Average Salary</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card">
            <div class="stat-icon bg-purple">
                <i class="bi bi-trophy-fill"></i>
            </div>
            <div>
                <div class="stat-value">@ViewBag.TopDepartmentName</div>
                <div class="stat-label">Top Department (@ViewBag.TopDepartmentCount employees)</div>
            </div>
        </div>
    </div>
</div>
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card stat-card">
            <h5 class="mb-3">Employees per Department</h5>
            <div style="position: relative; height: 250px;">
                <canvas id="departmentChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card stat-card">
            <h5 class="mb-3">Department Distribution</h5>
            <div style="position: relative; height: 250px;">
                <canvas id="departmentDoughnutChart"></canvas>
            </div>
        </div>
    </div>
</div>
<div class="table-card">
    <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
        <h6 class="mb-0">Recently Added Employees</h6>
        <a asp-controller="Employees" asp-action="Index" class="action-link">View All</a>
    </div>
    <table class="styled-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Department</th>
                <th>Date of Joining</th>
            </tr>
        </thead>
        <tbody>
            @if (ViewBag.RecentEmployees != null && ((IEnumerable<dynamic>)ViewBag.RecentEmployees).Any())
            {
                @foreach (var emp in ViewBag.RecentEmployees)
                {
                    <tr>
                        <td>@emp.FullName</td>
                        <td>@emp.Email</td>
                        <td><span class="badge-pill">@(emp.Department?.DepartmentName ?? "—")</span></td>
                        <td>@emp.DateOfJoining.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">No employees added yet.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        const chartLabels = @Html.Raw(Json.Serialize(ViewBag.ChartLabels));
        const chartData = @Html.Raw(Json.Serialize(ViewBag.ChartData));

        // Bar chart - Employees per Department
        const barCtx = document.getElementById('departmentChart').getContext('2d');
        new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Employees',
                    data: chartData,
                    backgroundColor: 'rgba(54, 162, 235, 0.6)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });

        // Doughnut chart - Department Distribution
        const doughnutColors = [
            'rgba(54, 162, 235, 0.8)',
            'rgba(46, 184, 92, 0.8)',
            'rgba(255, 159, 64, 0.8)',
            'rgba(153, 102, 255, 0.8)',
            'rgba(255, 99, 132, 0.8)',
            'rgba(255, 206, 86, 0.8)'
        ];

        const doughnutCtx = document.getElementById('departmentDoughnutChart').getContext('2d');
        new Chart(doughnutCtx, {
            type: 'doughnut',
            data: {
                labels: chartLabels,
                datasets: [{
                    data: chartData,
                    backgroundColor: doughnutColors,
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { boxWidth: 12, padding: 10 }
                    }
                }
            }
        });
    </script>
}