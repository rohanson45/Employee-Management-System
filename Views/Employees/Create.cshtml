@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Create";
}

<div class="page-header">
    <h2>Create Employee</h2>
</div>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control-custom" placeholder="Enter full name" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control-custom" placeholder="employee@example.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control-custom" placeholder="10-digit phone number" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Salary" class="form-label"></label>
                <input asp-for="Salary" class="form-control-custom" placeholder="e.g. 45000" />
                <span asp-validation-for="Salary" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DateOfJoining" class="form-label"></label>
                <input asp-for="DateOfJoining" class="form-control-custom" />
                <span asp-validation-for="DateOfJoining" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DepartmentId" class="form-label"></label>
                <select asp-for="DepartmentId" class="form-control-custom" asp-items="ViewBag.DepartmentId">
                    <option value="">-- Select Department --</option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <input type="submit" value="Create Employee" class="btn-create" />
            <a asp-action="Index" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>