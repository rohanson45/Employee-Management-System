@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Delete";
}

<div class="page-header">
    <h2>Delete Employee</h2>
</div>

<div class="form-card">
    <div class="delete-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>Are you sure you want to delete this employee? This action cannot be undone.</span>
    </div>

    <div class="detail-row">
        <span class="detail-label">Full Name</span>
        <span class="detail-value">@Html.DisplayFor(model => model.FullName)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Email</span>
        <span class="detail-value">@Html.DisplayFor(model => model.Email)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Phone Number</span>
        <span class="detail-value">@Html.DisplayFor(model => model.PhoneNumber)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Salary</span>
        <span class="detail-value">₹@Html.DisplayFor(model => model.Salary)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Date of Joining</span>
        <span class="detail-value">@Html.DisplayFor(model => model.DateOfJoining)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Department</span>
        <span class="detail-value">@(Model.Department?.DepartmentName ?? "N/A")</span>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="EmployeeId" />
        <div class="form-actions">
            <input type="submit" value="Delete Employee" class="btn-delete-confirm" />
            <a asp-action="Index" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>