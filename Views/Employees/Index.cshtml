@model IEnumerable<EmployeeManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="page-header">
    <h2>Employees</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Employee
    </a>
</div>

<form asp-action="Index" method="get" class="mb-4 d-flex gap-2">
    <input type="text" name="searchString" value="@ViewBag.CurrentFilter"
           class="form-control" style="max-width:320px"
           placeholder="Search by name or department..." />
    <button type="submit" class="btn btn-outline-secondary">
        <i class="bi bi-search"></i> Search
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-x-lg"></i> Clear
    </a>
</form>

<div class="table-card">
    <table class="styled-table">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>
                    <a asp-action="Index"
                       asp-route-sortOrder="@ViewBag.SalarySortParam"
                       asp-route-searchString="@ViewBag.CurrentFilter"
                       class="text-dark text-decoration-none">
                        Salary <i class="bi bi-arrow-down-up"></i>
                    </a>
                </th>
                <th>
                    <a asp-action="Index"
                       asp-route-sortOrder="@ViewBag.DateSortParam"
                       asp-route-searchString="@ViewBag.CurrentFilter"
                       class="text-dark text-decoration-none">
                        Date of Joining <i class="bi bi-arrow-down-up"></i>
                    </a>
                </th>
                <th>Department</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.PhoneNumber</td>
                        <td>@item.Salary.ToString("N0")</td>
                        <td>@item.DateOfJoining.ToString("dd MMM yyyy")</td>
                        <td><span class="badge-pill">@(item.Department?.DepartmentName ?? "—")</span></td>
                        <td class="text-end">
                            <div class="action-links">
                                <a asp-action="Edit" asp-route-employeeid="@item.EmployeeId" class="action-link">Edit</a>
                                <a asp-action="Details" asp-route-employeeid="@item.EmployeeId" class="action-link">Details</a>
                                <a asp-action="Delete" asp-route-employeeid="@item.EmployeeId" class="action-link delete">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">No employees found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>