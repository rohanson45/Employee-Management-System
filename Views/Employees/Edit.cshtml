@model EmployeeManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Edit";
}

<div class="page-header">
    <h2>Edit Employee</h2>
</div>

<div class="form-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="EmployeeId" />

        <div class="form-grid">
            <div class="form-group">
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control-custom" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control-custom" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber" class="form-label"></label>
                <input asp-for="PhoneNumber" class="form-control-custom" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Salary" class="form-label"></label>
                <input asp-for="Salary" class="form-control-custom" />
                <span asp-validation-for="Salary" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DateOfJoining" class="form-label"></label>
                <input asp-for="DateOfJoining" class="form-control-custom" />
                <span asp-validation-for="DateOfJoining" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DepartmentId" class="form-label"></label>
                <select asp-for="DepartmentId" class="form-control-custom" asp-items="ViewBag.DepartmentId"></select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>
        </div>

        <div class="form-actions">
            <input type="submit" value="Save Changes" class="btn-create" />
            <a asp-action="Index" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}