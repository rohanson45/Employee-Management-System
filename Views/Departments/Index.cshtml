@model IEnumerable<EmployeeManagementSystem.Models.Department>

@{
    ViewData["Title"] = "Departments";
}

<div class="page-header">
    <h2>Departments</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Department
    </a>
</div>

<div class="row g-4">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card dept-card">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="stat-icon bg-blue">
                            <i class="bi bi-diagram-3-fill"></i>
                        </div>
                        <span class="badge-pill">@item.Employees?.Count people</span>
                    </div>
                    <h5 class="mt-3 mb-1">@item.DepartmentName</h5>
                    <p class="text-muted small mb-3">@(item.Employees?.Count ?? 0) employee(s) assigned</p>
                    <div class="d-flex gap-3">
                        <a asp-action="Edit" asp-route-departmentid="@item.DepartmentId" class="action-link">Edit</a>
                        <a asp-action="Details" asp-route-departmentid="@item.DepartmentId" class="action-link">Details</a>
                        <a asp-action="Delete" asp-route-departmentid="@item.DepartmentId" class="action-link delete">Delete</a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="card text-center py-5 text-muted">
                No departments added yet. Click "Add Department" to create one.
            </div>
        </div>
    }
</div>