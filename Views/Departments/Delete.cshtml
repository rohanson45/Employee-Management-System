@model EmployeeManagementSystem.Models.Department

@{
    ViewData["Title"] = "Delete";
}

<div class="page-header">
    <h2>Delete Department</h2>
</div>

<div class="form-card">
    <div class="delete-warning">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>Are you sure you want to delete this department? All employees linked to it will also be removed.</span>
    </div>

    <div class="detail-row">
        <span class="detail-label">Department Name</span>
        <span class="detail-value">@Html.DisplayFor(model => model.DepartmentName)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Total Employees</span>
        <span class="detail-value">@(Model.Employees?.Count ?? 0)</span>
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="DepartmentId" />
        <div class="form-actions">
            <input type="submit" value="Delete Department" class="btn-delete-confirm" />
            <a asp-action="Index" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>