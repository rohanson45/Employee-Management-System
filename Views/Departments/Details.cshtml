@model EmployeeManagementSystem.Models.Department

@{
    ViewData["Title"] = "Details";
}

<div class="page-header">
    <h2>Department Details</h2>
</div>

<div class="form-card">
    <div class="detail-row">
        <span class="detail-label">Department Name</span>
        <span class="detail-value">@Html.DisplayFor(model => model.DepartmentName)</span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Total Employees</span>
        <span class="detail-value">@(Model.Employees?.Count ?? 0)</span>
    </div>

    <div class="form-actions">
        <a asp-action="Edit" asp-route-departmentid="@Model?.DepartmentId" class="btn-create">Edit</a>
        <a asp-action="Index" class="btn-cancel">Back to List</a>
    </div>
</div>