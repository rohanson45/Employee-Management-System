@model EmployeeManagementSystem.Models.Department

@{
    ViewData["Title"] = "Create";
}

<div class="page-header">
    <h2>Create Department</h2>
</div>

<div class="form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group">
            <label asp-for="DepartmentName" class="form-label"></label>
            <input asp-for="DepartmentName" class="form-control-custom" placeholder="e.g. Human Resources" />
            <span asp-validation-for="DepartmentName" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <input type="submit" value="Create Department" class="btn-create" />
            <a asp-action="Index" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>