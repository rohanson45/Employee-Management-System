@model EmployeeManagementSystem.Models.Department

@{
    ViewData["Title"] = "Edit";
}

<div class="page-header">
    <h2>Edit Department</h2>
</div>

<div class="form-card">
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="DepartmentId" />

        <div class="form-group">
            <label asp-for="DepartmentName" class="form-label"></label>
            <input asp-for="DepartmentName" class="form-control-custom" />
            <span asp-validation-for="DepartmentName" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <input type="submit" value="Save Changes" class="btn-create" />
            <a asp-action="Index" class="btn-cancel">Cancel</a>
        </div>
    </form>
</div>